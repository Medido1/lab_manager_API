generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())
  username String @unique
  password String
  approved Boolean @default(false)
  role Role @default(USER)
}

model Session {
  id String @id
  sid String @unique
  data String 
  expiresAt DateTime
}

enum Role  {
  USER
  ADMIN
}

model ClientData {
  id Int @id @default(autoincrement())
  type String 
  number Int 
  fullName String 
  price Decimal @db.Decimal(8, 2)
  remaining Decimal @db.Decimal(8, 2)
  phoneNumber String?
  createdAt DateTime @default(now())
  updatedAT DateTime @updatedAt
}